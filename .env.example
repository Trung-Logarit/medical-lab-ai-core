# LLM providers. Leave blank to disable a provider.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
COLAB_LLM_URL=
COLAB_API_KEY=
COLAB_MAX_NEW_TOKENS=970
COLAB_TEMPERATURE=0.2
COLAB_TIMEOUT=300
LOCAL_LLM_URL=http://localhost:11434/api/generate
LOCAL_LLM_MODEL=gemma3:1b

# Vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=lab_kb
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Knowledge graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Runtime
REQUEST_TIMEOUT=300

# OCR runtime. Use mobile for faster local demos; server favors accuracy.
OCR_PRELOAD=true
OCR_MODEL_PROFILE=mobile
OCR_DEVICE=auto
